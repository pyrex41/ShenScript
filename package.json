{
  "name": "shen-script",
  "version": "1.0.0",
  "description": "Shen for JavaScript",
  "keywords": [
    "shen",
    "language"
  ],
  "author": "Robert Koeninger",
  "license": "BSD-3-Clause",
  "repository": "github:rkoeninger/ShenScript",
  "type": "module",
  "main": "./lib/shen.node.js",
  "exports": {
    ".": {
      "browser": "./lib/shen.web.js",
      "default": "./lib/shen.node.js"
    },
    "./backend": "./lib/backend.js",
    "./streams": "./lib/streams.node.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "shen-script": "./bin/shen.js",
    "ratatoskr-build": "./bin/ratatoskr-build.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "lib/*.js",
    "bin/*.js",
    "kernel/LICENSE.txt"
  ],
  "devDependencies": {
    "c8": "^10.1.3",
    "eslint": "^8.24.0",
    "mocha": "^10.0.0",
    "mocha-each": "^2.0.1",
    "parsimmon": "^1.18.1",
    "terser-webpack-plugin": "^5.3.6",
    "webpack": "^5.74.0",
    "webpack-cli": "^4.10.0"
  },
  "dependencies": {
    "astring": "^1.8.3"
  },
  "scripts": {
    "lint": "eslint index.*.js bin/*.js lib/**/*.js scripts/**/*.js test/**/*.js --ignore-pattern lib/kernel.js",
    "test": "npm run test-backend && npm run test-cli && npm run test-frontend && npm run test-kernel && npm run test-kernel-extensions",
    "vendor-kernel": "node scripts/vendor.js",
    "verify-kernel": "node scripts/verify-kernel.js",
    "test-backend": "mocha test/backend/test.*.js --reporter dot --timeout 30000",
    "test-cli": "mocha test/cli/test.*.js --reporter dot --timeout 70000",
    "test:cert": "npm run test-kernel",
    "test:coverage": "c8 --reporter=text --reporter=html mocha test/backend/test.*.js test/cli/test.*.js --timeout 70000",
    "render-kernel": "node scripts/render.js",
    "test-kernel": "node test/kernel/test.kernel.js",
    "test-kernel-bun": "bun test/kernel/test.kernel.js",
    "test-kernel-deno": "deno run --allow-read --allow-write --allow-env test/kernel/test.kernel.js",
    "test-kernel-extensions": "node test/kernel/test.extensions.js",
    "test-smoke": "node test/smoke.js",
    "test-ratatoskr": "node test/ratatoskr/test.ratatoskr.js",
    "test-smoke-bun": "bun test/smoke.js",
    "test-smoke-deno": "deno run --allow-read --allow-env test/smoke.js",
    "test-frontend": "mocha test/frontend/test.*.js --reporter dot --timeout 5000",
    "repl": "node bin/shen.js repl",
    "start": "webpack-cli --watch --env mode=development",
    "bundle-dev": "webpack-cli --env mode=development",
    "bundle": "webpack-cli --env mode=production",
    "bundle-min": "webpack-cli --env mode=production --env min",
    "bundles": "npm run bundle-dev && npm run bundle && npm run bundle-min"
  }
}
